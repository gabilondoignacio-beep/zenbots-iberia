# ZENBOTS IBERIA — Configuración de entorno
# Copia este archivo a .env y rellena tus valores
# Uso: source .env && python3 app.py

# ── SERVIDOR ──────────────────────────────────────────
PORT=3000
ADMIN_TOKEN=ZenbotsAdmin2024!

# ── EMAIL SMTP ────────────────────────────────────────
# Opción A: Gmail con contraseña de aplicación
#   1. Ir a myaccount.google.com > Seguridad > Verificación en 2 pasos
#   2. Abajo: "Contraseñas de aplicación" > Generar
#   3. Copiar la clave de 16 caracteres en SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucuenta@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Opción B: Zoho Mail (info@zenbots.es)
# SMTP_HOST=smtp.zoho.eu
# SMTP_PORT=587
# SMTP_USER=info@zenbots.es
# SMTP_PASS=tu_contraseña_zoho

# Opción C: Brevo (SendinBlue) — 300 emails/día gratis
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=tu_login_brevo
# SMTP_PASS=tu_api_key_brevo

FROM_EMAIL=info@zenbots.es
FROM_NAME=ZENBOTS IBERIA

# ── EMPRESA ───────────────────────────────────────────
COMPANY_PHONE=+34 910 000 000
COMPANY_ADDRESS=Calle de Alcalá 50, 2ºA, 28014 Madrid
